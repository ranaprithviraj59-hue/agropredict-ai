# CropAI local configuration

# Admin panel key. Change this before a real deployment.
ADMIN_KEY=admin123

# Optional: personal data.gov.in API key for live Indian mandi prices.
# If empty, the app uses the public sample key from data.gov.in for testing.
# The sample key is rate-limited and returns a maximum of 10 records.
DATA_GOV_API_KEY=

# Optional: OpenRouter key for richer Kisan AI chat responses.
# Without this key, the project uses the built-in local Kisan advisory engine.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Optional: Hugging Face Inference Providers token for Kisan AI chat.
# Used if OpenRouter is not configured. Create a token with Inference Providers permission.
HF_TOKEN=
HUGGINGFACE_MODEL=openai/gpt-oss-120b:fastest
